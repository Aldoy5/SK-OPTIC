rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Modèle de Données
    // ===============================================================
    // Collection: products
    // Collection: orders
    // Collection: appointments
    // Collection: promotions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email in ["alexachie14@gmail.com", "amaniserge25@gmail.com"]);
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerName', 'customerContact', 'customerAddress', 'items', 'total', 'status', 'createdAt']) &&
             data.customerName is string && data.customerName.size() > 0 &&
             data.customerContact is string && data.customerContact.size() > 0 &&
             data.customerAddress is string && data.customerAddress.size() > 0 &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'validated', 'shipped', 'cancelled'] &&
             data.createdAt is timestamp;
    }

    function isValidAppointment(data) {
      return data.keys().hasAll(['name', 'email', 'phone', 'date', 'time', 'reason', 'status', 'createdAt']) &&
             data.name is string && data.name.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.phone is string && data.phone.size() > 0 &&
             data.date is string && data.date.size() > 0 &&
             data.time is string && data.time.size() > 0 &&
             data.reason is string && data.reason.size() > 0 &&
             data.status in ['pending', 'confirmed', 'cancelled'] &&
             data.createdAt is timestamp;
    }

    function isValidPromotion(data) {
      return data.keys().hasAll(['title', 'description', 'type', 'value', 'minQuantity', 'isActive']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 120 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 500 &&
             data.type in ['percentage', 'fixed'] &&
             data.value is number && data.value > 0 &&
             data.minQuantity is number && data.minQuantity >= 1 &&
             data.isActive is bool;
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidProduct(request.resource.data);
    }

    match /orders/{orderId} {
      allow read: if isAdmin();
      allow create: if isValidOrder(request.resource.data);
      allow update, delete: if isAdmin() && isValidOrder(request.resource.data);
    }

    match /appointments/{appointmentId} {
      allow read: if isAdmin();
      allow create: if isValidAppointment(request.resource.data);
      allow update, delete: if isAdmin() && isValidAppointment(request.resource.data);
    }

    match /promotions/{promotionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidPromotion(request.resource.data);
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
