rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Fields:
    //   - name: string (required)
    //   - price: number (required)
    //   - image: string
    //   - category: string (required)
    //   - description: string
    //
    // Collection: orders
    // Fields:
    //   - customerEmail: string (required)
    //   - items: list (required)
    //   - total: number (required)
    //   - status: string (required, enum: ['pending', 'validated', 'shipped', 'cancelled'])
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((request.auth.token.email == "alexachie14@gmail.com" || request.auth.token.email == "amaniserge25@gmail.com") && request.auth.token.email_verified == true);
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['items', 'total', 'status', 'createdAt']) &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'validated', 'shipped', 'cancelled'] &&
             data.createdAt is timestamp;
    }

    // Rules
    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAdmin();
      allow create: if isValidOrder(request.resource.data);
      allow update: if isAdmin() && isValidOrder(request.resource.data);
      allow delete: if isAdmin();
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
